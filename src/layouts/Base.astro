---
import "../styles/global.css";

// Self-hosted Inter (latin subset). Same-origin + font-display:swap removes the
// render-blocking Google Fonts request chain (DNS → TLS → CSS → font).
import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-500.css";
import "@fontsource/inter/latin-600.css";
import "@fontsource/inter/latin-700.css";

import ScrollTint from "../components/scroll-tint/ScrollTint.astro";
import CursorGlow from "../components/cursor-glow/CursorGlow.astro";
import Reveal from "../components/motion/Reveal.astro";
import SmoothScroll from "../components/motion/SmoothScroll.astro";
// Vercel Web Analytics — same-origin script (/_vercel/insights/*), so the
// strict 'self' CSP covers it. Must also be toggled on in Vercel → Analytics.
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Prodgeek Lab — Let's build something, together",
  description = "An AI venture studio. Bring your idea; I build the brutal last 30% and ship it — for a small stake. Pitch me.",
} = Astro.props;

// Canonical + absolute asset URLs resolve against `site` in astro.config.mjs.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og-image.png", Astro.site).href;

// Structured data — an AI venture studio (ProfessionalService) and its founder.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Prodgeek Lab",
  url: Astro.site?.href,
  description,
  image: ogImage,
  areaServed: "Toronto, Canada",
  founder: {
    "@type": "Person",
    name: "Prateek",
    jobTitle: "AI builder & founder",
  },
  sameAs: [
    "https://github.com/schuligan",
    "https://www.linkedin.com/in/prateekjha6",
    "https://www.youtube.com/@Beatoid",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0b0d14" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Prodgeek Lab" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Prodgeek Lab" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_CA" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <ScrollTint />
    <CursorGlow />
    <slot />
    <Reveal />
    <SmoothScroll />
    <Analytics />
  </body>
</html>
