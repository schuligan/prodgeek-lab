---
import "../styles/global.css";
import ScrollTint from "../components/scroll-tint/ScrollTint.astro";
import CursorGlow from "../components/cursor-glow/CursorGlow.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Prodgeek Lab — Let's build something, together",
  description = "An AI venture studio. Bring your idea; I build the brutal last 30% and ship it — for a small stake. Pitch me.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Inter — preconnect + the weights the design uses -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <ScrollTint />
    <CursorGlow />
    <slot />
  </body>
</html>
