---
import Base from "../layouts/Base.astro";
import Hero from "../components/hero/Hero.astro";
import WhyMe from "../components/why-me/WhyMe.astro";
import Mirror from "../components/mirror/Mirror.astro";
import About from "../components/about/About.astro";
import Pitch from "../components/pitch/Pitch.astro";
import Footer from "../components/footer/Footer.astro";

// Modular composition: each block is isolated under src/components/<feature>/.
// Phase 2 layers in the scroll-tint controller, hero aurora/spotlight, and the
// Bullpen game island (src/modules/bullpen/) — none of which touch these blocks.
---

<Base>
  <main>
    <Hero />
    <WhyMe />
    <Mirror />
    <About />
    <Pitch />
  </main>
  <Footer />
</Base>
