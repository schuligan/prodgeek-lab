---
import offer from "../../content/offer.json";
import site from "../../content/site.json";
const { mirror } = offer;
const hasBooking = site.booking.bookingUrl && !site.booking.bookingUrl.startsWith("REPLACE");
const tagHref = hasBooking ? site.booking.bookingUrl : "#pitch";
---

<section class="mirror" aria-labelledby="mirror-heading" data-tint="rgba(168,85,247,.46)">
  <div class="inner">
    <p class="label">Sound like you?</p>
    <h2 id="mirror-heading">{mirror.heading}</h2>
    <ul>
      {mirror.points.map((point) => <li>{point}</li>)}
    </ul>
    <a class="tag" href={tagHref}>{mirror.tag}</a>
  </div>
</section>

<style>
  .mirror {
    position: relative;
    padding: var(--space-section) clamp(1.5rem, 5vw, 4rem);
    background: radial-gradient(120% 80% at 80% 0%, #241733 0%, var(--color-bg) 60%);
  }
  .inner { max-width: 820px; margin-inline: auto; }
  .label { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-violet); margin: 0 0 0.9rem; }
  h2 { font-size: var(--text-h2); font-weight: 640; letter-spacing: -0.015em; margin: 0 0 1.2rem; max-width: 18ch; color: #fff; }
  ul { margin: 0 0 1.4rem; padding-left: 1.1rem; }
  li { font-size: 0.98rem; line-height: 1.8; color: var(--color-dim); }
  .tag {
    display: inline-block; font-size: 0.85rem; color: var(--color-violet); text-decoration: none;
    border: 1px solid rgba(200, 155, 255, 0.35); padding: 0.55rem 1rem; border-radius: 999px;
    transition: background 0.2s, transform 0.15s, border-color 0.2s;
  }
  .tag:hover { background: rgba(200, 155, 255, 0.12); border-color: rgba(200, 155, 255, 0.6); transform: translateY(-1px); }
</style>
