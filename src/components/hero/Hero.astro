---
import site from "../../content/site.json";
import offer from "../../content/offer.json";
import Bullpen from "../../modules/bullpen/Bullpen.astro";
const { hero, deal } = offer;
---

<section class="hero" aria-labelledby="hero-heading" data-tint="rgba(108,140,255,.5)">
  <!-- PRO-14: ambient aurora drift + cursor-tracked spotlight (GPU-only) -->
  <div class="aurora" aria-hidden="true">
    <span class="blob b1"></span>
    <span class="blob b2"></span>
    <span class="blob b3"></span>
  </div>
  <div class="spotlight" id="hero-spotlight" aria-hidden="true"></div>

  <nav class="nav" aria-label="Main navigation">
    <span class="logo">{site.brand}</span>
    <ul class="navlinks">
      {site.nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
    </ul>
    <a class="nav-cta" id="bp-target" href={site.cta.href}>Pitch me</a>
  </nav>

  <div class="inner">
    <p class="eyebrow">{hero.eyebrow}</p>
    <h1 id="hero-heading" class="h1">{hero.headline}</h1>
    <p class="sub" set:html={hero.sub} />

    <div class="cta">
      <Bullpen />
    </div>

    <ul class="deal" aria-label="How it works">
      {deal.map((step) => (
        <li class="step">
          <span class="n">{step.n}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding: 6rem clamp(1.5rem, 5vw, 4rem) 4rem;
    background: radial-gradient(120% 90% at 78% 8%, #1b2440 0%, var(--color-bg) 58%);
    overflow: hidden;
  }

  /* aurora */
  .aurora { position: absolute; inset: 0; z-index: 0; }
  .blob {
    position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.4;
    will-change: transform;
  }
  .b1 { width: 38vw; height: 38vw; background: #2f4bc4; top: -12vw; right: -6vw; animation: drift-a 30s ease-in-out infinite; }
  .b2 { width: 32vw; height: 32vw; background: #0b8f72; bottom: -14vw; left: -8vw; animation: drift-b 38s ease-in-out infinite; }
  .b3 { width: 28vw; height: 28vw; background: #5a3fc0; top: 30%; left: 40%; opacity: 0.3; animation: drift-c 34s ease-in-out infinite; }
  @keyframes drift-a { 0%, 100% { transform: translate(0, 0) scale(1); } 50% { transform: translate(-3vw, 4vw) scale(1.08); } }
  @keyframes drift-b { 0%, 100% { transform: translate(0, 0) scale(1); } 50% { transform: translate(4vw, -2.6vw) scale(1.06); } }
  @keyframes drift-c { 0%, 100% { transform: translate(0, 0) scale(1); } 50% { transform: translate(-2.6vw, -3vw) scale(0.94); } }

  /* cursor spotlight */
  .spotlight {
    position: absolute; inset: 0; z-index: 2; pointer-events: none; mix-blend-mode: screen;
    background: radial-gradient(
      560px 560px at var(--mx, 60%) var(--my, 30%),
      rgba(127, 231, 214, 0.30), rgba(108, 140, 255, 0.16) 42%, transparent 72%
    );
    transition: background 0.1s linear;
  }

  .nav, .inner { position: relative; z-index: 3; }

  .nav {
    position: absolute; top: clamp(1.4rem, 4vw, 2.4rem);
    left: clamp(1.5rem, 5vw, 4rem); right: clamp(1.5rem, 5vw, 4rem);
    display: flex; align-items: center; gap: 1.5rem;
  }
  .logo { font-weight: 700; letter-spacing: -0.01em; }
  .navlinks { display: flex; gap: 1.4rem; list-style: none; margin: 0 auto 0 1.5rem; padding: 0; }
  .navlinks a { color: var(--color-dim); text-decoration: none; font-size: 0.85rem; }
  .navlinks a:hover { color: var(--color-mint); }
  .nav-cta {
    position: relative; font-size: 0.9rem; font-weight: 700; color: var(--color-mint); text-decoration: none;
    border: 1px solid rgba(127, 231, 214, 0.4); padding: 0.7rem 1.4rem 0.6rem; border-radius: 16px 16px 999px 999px;
    background: radial-gradient(120% 150% at 50% 130%, rgba(11, 143, 114, 0.28), transparent 70%);
    transition: transform 0.15s, box-shadow 0.3s;
  }
  /* stadium lights along the top of the "park" */
  .nav-cta::before {
    content: ""; position: absolute; top: -7px; left: 50%; transform: translateX(-50%);
    width: 72%; height: 3px; border-radius: 3px; opacity: 0.5;
    background: radial-gradient(circle, #fff 0 1px, transparent 1.6px) repeat-x; background-size: 9px 3px;
  }
  .nav-cta:hover { transform: translateY(-1px); }
  .nav-cta.hit { animation: bp-target-hit 0.7s cubic-bezier(0.16, 1, 0.3, 1); }
  @keyframes bp-target-hit {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(127, 231, 214, 0.6); }
    30% { transform: scale(1.18); box-shadow: 0 0 0 14px rgba(127, 231, 214, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(127, 231, 214, 0); }
  }
  .inner { max-width: 1100px; margin-inline: auto; width: 100%; }
  .eyebrow { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-mint); margin: 0 0 1rem; }
  .h1 {
    font-size: var(--text-hero); line-height: 1.04; font-weight: 650;
    letter-spacing: -0.025em; margin: 0 0 1.2rem; max-width: 16ch; color: #fff;
  }
  .sub { font-size: 1rem; line-height: 1.62; color: var(--color-dim); max-width: 52ch; margin: 0 0 2rem; }
  .cta { display: flex; flex-direction: column; align-items: flex-start; gap: 0.5rem; margin-bottom: 3rem; }
  .ball-link {
    display: inline-block; font-weight: 600; padding: 0.85rem 1.6rem; border-radius: 999px;
    background: var(--grad-accent); color: var(--color-bg); text-decoration: none;
    transition: transform var(--dur-normal) var(--ease-out-expo);
  }
  .ball-link:hover { transform: translateY(-2px); }
  .hint { font-size: 0.75rem; color: var(--color-faint); }

  .deal { display: grid; grid-template-columns: 1fr; gap: 0.9rem; list-style: none; margin: 0; padding: 0; max-width: 880px; }
  @media (min-width: 800px) { .deal { grid-template-columns: repeat(3, 1fr); } }
  .step { background: var(--color-surface); border: 1px solid rgba(255, 255, 255, 0.07); border-radius: 14px; padding: 1.1rem 1rem; }
  .step .n { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-mint); }
  .step h3 { margin: 0.45rem 0 0.35rem; font-size: 1rem; color: #fff; }
  .step p { margin: 0; font-size: 0.82rem; line-height: 1.5; color: var(--color-dim); }

  @media (max-width: 640px) { .navlinks { display: none; } .nav { gap: 0; justify-content: space-between; } }
  @media (prefers-reduced-motion: reduce) {
    .blob { animation: none; }
    .spotlight { display: none; }
  }
</style>

<script>
  const hero = document.querySelector<HTMLElement>(".hero");
  const spotlight = document.getElementById("hero-spotlight");
  if (hero && spotlight && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    hero.addEventListener("pointermove", (e) => {
      const r = hero.getBoundingClientRect();
      spotlight.style.setProperty("--mx", `${((e.clientX - r.left) / r.width) * 100}%`);
      spotlight.style.setProperty("--my", `${((e.clientY - r.top) / r.height) * 100}%`);
    });
  }
</script>
