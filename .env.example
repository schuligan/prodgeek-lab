# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).
# These are read server-side only — none are exposed in the website HTML.

# Where the contact form / booking notifications go. Server-only; never in client code.
CONTACT_EMAIL=you@example.com

# --- Game leaderboard (v2 only — not needed for v1) ---
# Supabase project (server-side service key stays secret; anon key is public + RLS-protected)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
