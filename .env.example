# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).
# These are read server-side only — none are exposed in the website HTML.

# Where the contact form / booking notifications go. Server-only; never in client code.
CONTACT_EMAIL=you@example.com

# --- Game leaderboard (PRO-28) ---
# Supabase. Anti-cheat lives in the `submit_score` security-definer RPC, so only
# the publishable anon key is used (no service-role secret). RLS allows public
# reads; writes are only possible through the validating RPC.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-anon-key

# Optional goodie email (lead magnet) — server-only. Without these the score
# still saves; the email is just skipped. Get a key at resend.com (free tier).
RESEND_API_KEY=
GOODIE_FROM_EMAIL=Prodgeek Lab <onboarding@resend.dev>
